{
  "name": "back",
  "version": "1.0.0",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "start:cluster": "pm2 start ecosystem.config.cjs --env production",
    "start:cluster:canary": "pm2 start ecosystem.config.cjs --env canary --only greenbit-api",
    "stop:cluster": "pm2 delete greenbit-api",
    "reload:cluster": "pm2 reload greenbit-api",
    "logs:cluster": "pm2 logs greenbit-api --lines 200",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:routes": "node test-all-routes.js",
    "test:report": "node test-routes-report.js",
    "perf:smoke": "artillery run Scripts/performance/artillery/smoke.yml --output Scripts/performance/reports/smoke.json",
    "perf:load": "artillery run Scripts/performance/artillery/load-500.yml --output Scripts/performance/reports/load-500.json",
    "perf:score-race": "artillery run Scripts/performance/artillery/score-race.yml --output Scripts/performance/reports/score-race.json",
    "perf:generate-csv": "node Scripts/performance/generate-users-csv.mjs",
    "perf:setup-qa": "node Scripts/performance/setup-qa-accounts.mjs",
    "perf:validate-csv": "node Scripts/performance/validate-users-csv.mjs",
    "perf:report:smoke": "artillery report Scripts/performance/reports/smoke.json --output Scripts/performance/reports/smoke.html",
    "perf:report:load": "artillery report Scripts/performance/reports/load-500.json --output Scripts/performance/reports/load-500.html",
    "perf:report:score-race": "artillery report Scripts/performance/reports/score-race.json --output Scripts/performance/reports/score-race.html",
    "perf:analyze": "node Scripts/performance/analyze-artillery-report.mjs",
    "ops:monitor:ready": "node Scripts/ops/monitor-readiness.mjs",
    "ops:smoke:daily": "node Scripts/ops/smoke-daily-check.mjs",
    "verify": "node ../scripts/verify-setup.js",
    "setup": "npm install && npm run verify"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "mysql2": "^3.14.5",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "nodemon": "^3.1.10",
    "resend": "^6.0.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "artillery": "^2.0.22",
    "pm2": "^6.0.14"
  }
}
